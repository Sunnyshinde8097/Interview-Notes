using System;
using System.Linq;
using System.Collections.Generic;

public class HelloWorld
{   
    public class Employee
    {
       public int Id { get; set; }
       public string EmployeeName { get; set; }
       public string Department { get; set; }
    }

    public static void Main(string[] args)
    {

      List<Employee> EMP = new List<Employee>();
      EMP.Add(new Employee{Id=1,EmployeeName="Sunny Shinnde",Department="IT"});
      EMP.Add(new Employee{Id=2,EmployeeName="Lata Shinnde",Department="Maintance"});
      EMP.Add(new Employee{Id=3,EmployeeName="Sumit Patil",Department="HR"});
      EMP.Add(new Employee{Id=4,EmployeeName="madu Patil",Department="HR"});
      
    var result = EMP.Skip((0-1)*0).Take(2).ToList();
     foreach (var emp in result)
        {
            Console.WriteLine($"ID: {emp.Id}, Name: {emp.EmployeeName}, Dept: {emp.Department}");
        }

    }
}